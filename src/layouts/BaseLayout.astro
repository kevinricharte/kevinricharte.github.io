---
import '@fontsource/cormorant-garamond/300.css';
import '@fontsource/cormorant-garamond/400.css';
import '@fontsource/cormorant-garamond/500.css';
import '@fontsource/cormorant-garamond/300-italic.css';
import '@fontsource/cormorant-garamond/400-italic.css';
import '@fontsource-variable/inter';
import '../styles/global.css';

import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SEO from '../components/SEO.astro';
import { getLangFromUrl, useTranslations, altLangPath, enActive } from '../i18n/utils';

interface Props {
  title: string;
  description?: string;
  image?: string;
  lang?: 'fr' | 'en';
  padded?: boolean;      // décale le contenu sous le header fixe
  heroHeader?: boolean;  // header transparent (page avec hero plein écran)
}
const { title, description, image, padded = true, heroHeader = false } = Astro.props;
const lang = Astro.props.lang ?? getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const altFr = altLangPath(Astro.url.pathname, 'fr');
const altEn = altLangPath(Astro.url.pathname, 'en');
---
<!doctype html>
<html lang={lang} data-alt-fr={altFr} data-alt-en={altEn}>
  <head>
    <SEO title={title} description={description} image={image} />
    {enActive && (
      <script is:inline>
        (function () {
          try {
            var root = document.documentElement;
            var cur = root.getAttribute('lang');
            var altFr = root.getAttribute('data-alt-fr');
            var altEn = root.getAttribute('data-alt-en');
            var KEY = 'langPref';
            var pref = localStorage.getItem(KEY);
            // 1) Respecte un choix manuel mémorisé
            if (pref === 'en' && cur === 'fr' && altEn) { location.replace(altEn); return; }
            if (pref === 'fr' && cur === 'en' && altFr) { location.replace(altFr); return; }
            // 2) Première visite : détection de la langue du navigateur
            if (!pref) {
              var wantsEn = (navigator.language || '').toLowerCase().slice(0, 2) === 'en';
              if (wantsEn && cur === 'fr' && altEn) { location.replace(altEn); return; }
            }
            // 3) Mémorise le choix quand on clique sur le sélecteur FR/EN
            document.addEventListener('click', function (e) {
              var a = e.target && e.target.closest && e.target.closest('.lang-switch a');
              if (a) {
                try { localStorage.setItem(KEY, a.textContent.trim().toLowerCase() === 'en' ? 'en' : 'fr'); } catch (_) {}
              }
            });
          } catch (e) {}
        })();
      </script>
    )}
  </head>
  <body>
    <a class="skip-link" href="#main">{t('skip')}</a>
    <div class="grain-overlay" aria-hidden="true"></div>
    <Header lang={lang} transparent={heroHeader} />
    <main id="main" class:list={[{ padded }]}>
      <slot />
    </main>
    <Footer lang={lang} />

    <style>
      main.padded { padding-top: var(--header-h); }
    </style>

    <script>
      // Apparitions au scroll — parcimonie (brief §5.4.3)
      const els = document.querySelectorAll('.reveal');
      const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (els.length && !reduce) {
        const io = new IntersectionObserver((entries) => {
          for (const e of entries) {
            if (e.isIntersecting) { e.target.classList.add('is-visible'); io.unobserve(e.target); }
          }
        }, { rootMargin: '0px 0px -12% 0px', threshold: 0.1 });
        els.forEach((el) => io.observe(el));
      } else {
        els.forEach((el) => el.classList.add('is-visible'));
      }
    </script>
  </body>
</html>
