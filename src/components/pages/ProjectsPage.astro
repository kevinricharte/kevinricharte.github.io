---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import ProjectCard from '../ProjectCard.astro';
import reglages from '../../data/reglages.json';
import { typoLabel } from '../../i18n/content';

interface Props { lang: 'fr' | 'en'; }
const { lang } = Astro.props;
const en = lang === 'en';

const projets = (await getCollection('projets', ({ data }) => !data.draft)).sort((a, b) => a.data.ordre - b.data.ordre);
const present = new Set(projets.flatMap((p) => p.data.typologies));

const configured = reglages.categoriesProjets;
const categories = (Array.isArray(configured) && configured.length)
  ? configured
      .filter((c) => c.visible && present.has(c.valeur))
      .map((c) => ({ valeur: c.valeur, label: en ? typoLabel(c.valeur, true) : ((c.label && c.label.trim()) ? c.label.trim() : c.valeur) }))
  : Array.from(present).sort((a, b) => a.localeCompare(b)).map((v) => ({ valeur: v, label: typoLabel(v, en) }));

const T = {
  title: en ? 'Projects — Kévin Richarte, fiction colorist' : 'Projets — Kévin Richarte, étalonneur fiction',
  description: en
    ? 'A selection of projects graded by Kévin Richarte — fiction, narrative music videos, brand content, advertising.'
    : 'Sélection de projets étalonnés par Kévin Richarte — fiction, clip narratif, brand content, publicité.',
  eyebrow: en ? 'Projects' : 'Projets',
  heading: en ? 'Selected graded projects' : 'Sélection de projets étalonnés',
  sub: en ? 'A colorist’s filmography — fiction, music videos, narrative brand content.' : 'Filmographie d’étalonneur — fiction, clip, brand content narratif.',
  all: en ? 'All' : 'Tous',
  empty: en ? 'No project in this category.' : 'Aucun projet dans cette catégorie.',
  emptyReset: en ? 'View all projects' : 'Voir tous les projets',
  filterAria: en ? 'Filter by category' : 'Filtrer par catégorie',
};
---
<BaseLayout title={T.title} lang={lang} description={T.description}>
  <section class="section container-wide">
    <header class="proj-head reveal">
      <p class="meta">{T.eyebrow}</p>
      <h1 class="proj-title">{T.heading}</h1>
      <p class="proj-sub">{T.sub}</p>
    </header>

    <div class="filters" role="group" aria-label={T.filterAria}>
      <button type="button" class="filter active" data-filter="*">{T.all}</button>
      {categories.map((c) => (
        <button type="button" class="filter" data-filter={c.valeur}>{c.label}</button>
      ))}
    </div>

    <ul role="list" class="project-grid" id="proj-grid">
      {projets.map((p) => <ProjectCard entry={p} lang={lang} />)}
    </ul>

    <p class="empty meta" id="proj-empty" hidden>
      {T.empty} <button type="button" class="empty-reset" data-filter="*">{T.emptyReset}</button>
    </p>
  </section>
</BaseLayout>

<style>
  .proj-head { max-width: 40ch; }
  .proj-title { font-size: var(--step-4); font-weight: 300; margin-top: 0.8rem; }
  .proj-sub { color: var(--ivoire-72); margin-top: 1rem; max-width: 46ch; }

  .filters { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 2.4rem; margin-bottom: 2.8rem; }
  .filter {
    font-family: var(--font-sans); font-size: 0.72rem; letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--brouillard); padding: 0.5rem 0.95rem; border: 1px solid var(--line); border-radius: 100px;
    transition: color var(--dur) var(--ease), border-color var(--dur) var(--ease);
  }
  .filter:hover { color: var(--ivoire); border-color: var(--brouillard); }
  .filter.active { color: var(--ivoire); border-color: var(--ambre); }

  .empty { margin-top: 2.5rem; }
  .empty-reset { color: var(--ambre); text-decoration: underline; text-underline-offset: 3px; }
</style>

<script>
  const grid = document.getElementById('proj-grid');
  if (grid) {
    const cards = Array.from(grid.querySelectorAll<HTMLElement>('.card'));
    const empty = document.getElementById('proj-empty');
    const filterBtns = Array.from(document.querySelectorAll<HTMLElement>('.filter'));

    const apply = (f: string) => {
      let visible = 0;
      cards.forEach((c) => {
        const typos = (c.dataset.typos || '').split('|');
        const show = f === '*' || typos.includes(f);
        c.hidden = !show;
        if (show) visible += 1;
      });
      if (empty) empty.hidden = visible > 0;
      filterBtns.forEach((b) => b.classList.toggle('active', b.dataset.filter === f));
    };

    document.querySelectorAll<HTMLElement>('[data-filter]').forEach((b) => {
      b.addEventListener('click', () => apply(b.dataset.filter || '*'));
    });
  }
</script>
