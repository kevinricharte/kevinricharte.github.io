---
import reglages from '../data/reglages.json';
interface Props {
  avant: string;
  apres: string;
  alt?: string;
  labelAvant?: string;
  labelApres?: string;
}
const {
  avant,
  apres,
  alt = '',
  labelAvant = 'REC.709',
  labelApres = 'Étalonné final',
} = Astro.props;
---
<figure class="ba" data-ba>
  <div class:list={["ba-frame", { "fit-natural": reglages.respecterFormatWipe }]}>
    <img class="ba-img" src={apres} alt={`${alt} — ${labelApres}`} />
    <div class="ba-before" data-ba-before>
      <img class="ba-img" src={avant} alt={`${alt} — ${labelAvant}`} />
    </div>

    <div class="ba-divider" data-ba-divider>
      <button class="ba-handle" type="button" aria-hidden="true" tabindex="-1">
        <span class="ba-arrows">‹ ›</span>
      </button>
    </div>

    <span class="ba-tag ba-tag--l">← {labelAvant}</span>
    <span class="ba-tag ba-tag--r">{labelApres} →</span>

    <input
      class="ba-range"
      type="range" min="0" max="100" value="50" step="0.5"
      aria-label={`Comparateur avant/après${alt ? ' — ' + alt : ''} : ${labelAvant} à gauche, ${labelApres} à droite`}
      data-ba-range
    />
  </div>
  <figcaption class="ba-caption meta">Glissez pour comparer — {labelAvant} / {labelApres}</figcaption>
</figure>

<style>
  .ba { margin: 0; }
  .ba-frame {
    position: relative; aspect-ratio: 16 / 9; overflow: hidden;
    background: var(--encre); border: 1px solid var(--line); user-select: none;
  }
  .ba-img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .ba-before { position: absolute; inset: 0; clip-path: inset(0 50% 0 0); will-change: clip-path; }

  /* Respect du format : le cadre prend le ratio de l'image (l'« après » définit la hauteur) */
  .ba-frame.fit-natural { aspect-ratio: auto; }
  .ba-frame.fit-natural > .ba-img { position: relative; inset: auto; width: 100%; height: auto; object-fit: contain; }

  .ba-divider {
    position: absolute; top: 0; bottom: 0; left: 50%; width: 2px; transform: translateX(-1px);
    background: var(--ivoire); box-shadow: 0 0 0 1px rgba(21,17,14,0.35); pointer-events: none;
  }
  .ba-handle {
    position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
    width: 46px; height: 46px; border-radius: 50%;
    background: var(--encre-92); border: 1px solid var(--ivoire);
    display: grid; place-items: center; color: var(--ivoire);
  }
  .ba-arrows { font-size: 1rem; letter-spacing: 0.05em; }

  .ba-tag {
    position: absolute; bottom: 0.9rem; font-family: var(--font-sans); font-size: 0.68rem;
    letter-spacing: 0.12em; text-transform: uppercase; color: var(--ivoire);
    background: var(--encre-70); padding: 0.35rem 0.6rem; backdrop-filter: blur(4px);
    pointer-events: none;
  }
  .ba-tag--l { left: 0.9rem; }
  .ba-tag--r { right: 0.9rem; }

  /* Range accessible superposé (transparent) — pilote le comparateur au clavier + pointeur */
  .ba-range {
    position: absolute; inset: 0; width: 100%; height: 100%; margin: 0; opacity: 0; cursor: ew-resize;
  }
  .ba-range:focus-visible { outline: none; }
  .ba-range:focus-visible ~ .ba-tag { outline: 2px solid var(--ambre); }
  .ba-frame:focus-within .ba-divider { background: var(--ambre); }

  .ba-caption { margin-top: 0.8rem; }

  @media (prefers-reduced-motion: reduce) { .ba-before { will-change: auto; } }
</style>

<script>
  document.querySelectorAll<HTMLElement>('[data-ba]').forEach((ba) => {
    const frame = ba.querySelector<HTMLElement>('.ba-frame')!;
    const before = ba.querySelector<HTMLElement>('[data-ba-before]')!;
    const divider = ba.querySelector<HTMLElement>('[data-ba-divider]')!;
    const range = ba.querySelector<HTMLInputElement>('[data-ba-range]')!;

    const apply = (x: number) => {
      const v = Math.max(0, Math.min(100, x));
      before.style.clipPath = `inset(0 ${100 - v}% 0 0)`;
      divider.style.left = `${v}%`;
    };
    // clavier / natif
    range.addEventListener('input', () => apply(parseFloat(range.value)));
    // pointeur (souris + tactile) : suit le curseur pendant le drag
    let dragging = false;
    const fromClientX = (clientX: number) => {
      const r = frame.getBoundingClientRect();
      const v = ((clientX - r.left) / r.width) * 100;
      range.value = String(v);
      apply(v);
    };
    frame.addEventListener('pointerdown', (e) => { dragging = true; frame.setPointerCapture(e.pointerId); fromClientX(e.clientX); });
    frame.addEventListener('pointermove', (e) => { if (dragging) fromClientX(e.clientX); });
    frame.addEventListener('pointerup', () => { dragging = false; });
    frame.addEventListener('pointercancel', () => { dragging = false; });

    apply(parseFloat(range.value));
  });
</script>
