---
import { getLangFromUrl } from '../i18n/utils';

interface Props {
  title: string;
  description?: string;
  image?: string;
}
const {
  title,
  description = "Kevin Richarte — étalonneur spécialisé fiction, région parisienne. Étalonnage créatif et technique de projets fiction, clip, documentaire et brand content narratif sur DaVinci Resolve Studio.",
  image = '/og/og-default.jpg',
} = Astro.props;

const lang = getLangFromUrl(Astro.url);
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL(image, Astro.site).href;
---
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
<meta name="theme-color" content="#15110e" />
<link rel="icon" href="/favicon.svg" type="image/svg+xml" />

<meta property="og:type" content="website" />
<meta property="og:site_name" content="Kevin Richarte" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImage} />
<meta property="og:locale" content={lang === 'fr' ? 'fr_FR' : 'en_US'} />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />

<meta name="generator" content={Astro.generator} />
