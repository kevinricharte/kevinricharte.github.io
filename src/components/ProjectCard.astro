---
import type { CollectionEntry } from 'astro:content';
import { thumb } from '../lib/media';
import reglages from '../data/reglages.json';
import { projectHref, typoLabel, projectGenres } from '../i18n/content';

interface Props { entry: CollectionEntry<'projets'>; lang?: 'fr' | 'en'; }
const { entry, lang = 'fr' } = Astro.props;
const en = lang === 'en';
const d = entry.data;
const cover = d.cover;
const title = en ? (d.titreEn?.trim() || d.titre) : d.titre;
const href = projectHref(entry.id, en);
// Classification : type de métrage (Clip, Fiction…) puis genre(s).
const type = d.typologiePrincipale ? typoLabel(d.typologiePrincipale, en) : undefined;
const classif = [type, ...projectGenres(d, en)].filter(Boolean).join(' · ') || undefined;
---
<li class="card" data-typos={d.typologies.join('|')} data-genres={d.genres.join('|')}>
  <a href={href} class="card-link">
    <div class:list={["card-media", { "fit-contain": reglages.respecterFormatVignette ?? true }]}>
      {cover && <img src={thumb(cover)} alt={d.coverAlt ?? title} class="card-img" loading="lazy" />}
      <div class="card-overlay" aria-hidden="true">
        <span class="card-otitle">{title}</span>
        {classif && <span class="card-otypo">{classif}</span>}
      </div>
    </div>
    <div class="card-meta">
      <span class="card-name">{title}</span>
      <span class="meta card-info">{d.annee ?? '—'}{classif ? ` · ${classif}` : ''}</span>
    </div>
  </a>
</li>

<style>
  .card-media { position: relative; aspect-ratio: 16 / 9; overflow: hidden; background: var(--cendre); }
  .card-img { width: 100%; height: 100%; object-fit: cover; transition: transform 600ms var(--ease); }
  /* Respect du format : image entière avec bandes noires au lieu de recadrer */
  .card-media.fit-contain { background: #000; }
  .card-media.fit-contain .card-img { object-fit: contain; }
  .card-link:hover .card-img, .card-link:focus-visible .card-img { transform: scale(1.04); }
  .card-overlay {
    position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center;
    gap: 0.5rem; text-align: center; padding: 1rem; background: rgba(21, 17, 14, 0.58); opacity: 0;
    transition: opacity var(--dur) var(--ease);
  }
  .card-link:hover .card-overlay, .card-link:focus-visible .card-overlay { opacity: 1; }
  .card-otitle { font-family: var(--font-serif); font-size: clamp(1.4rem, 2.5vw, 1.7rem); color: var(--ivoire); }
  .card-otypo { font-family: var(--font-sans); font-size: 0.68rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ambre); }
  .card-meta { margin-top: 0.9rem; display: flex; flex-direction: column; gap: 0.3rem; }
  .card-name { font-family: var(--font-serif); font-size: 1.2rem; color: var(--ivoire); }
  .card[hidden] { display: none; }
  @media (hover: none) { .card-overlay { display: none; } }
</style>
