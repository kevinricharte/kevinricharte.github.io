---
import { getRoutes, useTranslations, getLangFromUrl } from '../i18n/utils';
import LangSwitcher from './LangSwitcher.astro';
import { site } from '../data/site';
import reglages from '../data/reglages.json';

interface Props { lang?: 'fr' | 'en'; }
const lang = Astro.props.lang ?? getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const r = getRoutes(lang);
const year = new Date().getFullYear();

// Index de pages (l'onglet Formation suit le réglage du panneau)
const pages = [
  { href: r.home, label: t('nav.home') },
  { href: r.projects, label: t('nav.projects') },
  ...(reglages.afficherFormation ? [{ href: r.training, label: t('nav.training') }] : []),
  { href: r.about, label: t('nav.about') },
  { href: r.contact, label: t('nav.contact') },
];
---
<footer class="site-footer">
  <div class="container-wide footer-top">
    <div class="f-brand">
      <p class="f-name">Kévin Richarte</p>
      <p class="meta f-role">{t('footer.role')}</p>
    </div>

    <nav class="f-col" aria-label="Plan du site">
      <p class="meta f-h">Pages</p>
      <ul role="list">
        {pages.map((p) => <li><a href={p.href} class="f-link underline-accent">{p.label}</a></li>)}
      </ul>
    </nav>

    <nav class="f-col" aria-label="Liens externes">
      <p class="meta f-h">Ailleurs</p>
      <ul role="list">
        <li>
          <a href={site.showreelUrl} target="_blank" rel="noopener noreferrer" class="f-ext">
            <svg class="f-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M22 7.4c-.1 2.1-1.6 5-4.4 8.6-2.9 3.8-5.4 5.7-7.4 5.7-1.2 0-2.3-1.2-3.1-3.5-.6-2.1-1.1-4.2-1.7-6.3-.6-2.3-1.3-3.5-2-3.5-.2 0-.7.3-1.6.9L1 8.4c1-.9 2-1.8 3-2.7 1.3-1.2 2.3-1.8 3-1.9 1.6-.2 2.5 1 2.8 3.4.3 2.7.5 4.3.7 5 .5 2.3 1 3.4 1.7 3.4.5 0 1.2-.7 2.1-2.2.9-1.5 1.4-2.6 1.5-3.4.1-1-.3-1.5-1.3-1.5-.5 0-.9.1-1.4.3.9-2.9 2.6-4.3 5.1-4.2 1.9.1 2.7 1.3 2.6 3.8z"/></svg>
            <span class="underline-accent">Showreel</span>
          </a>
        </li>
        <li>
          <a href={site.instagramUrl} target="_blank" rel="noopener noreferrer" class="f-ext">
            <svg class="f-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1.1" fill="currentColor" stroke="none"/></svg>
            <span class="underline-accent">Instagram</span>
          </a>
        </li>
        <li>
          <a href={site.linkedinUrl} target="_blank" rel="noopener noreferrer" class="f-ext">
            <svg class="f-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M4.98 3.5A2.5 2.5 0 1 0 5 8.5a2.5 2.5 0 0 0 0-5zM3 9h4v12H3zM9 9h3.8v1.7h.05c.53-.95 1.83-1.95 3.77-1.95 4.03 0 4.78 2.5 4.78 5.75V21h-4v-5.3c0-1.26-.02-2.9-1.77-2.9-1.77 0-2.04 1.38-2.04 2.8V21H9z"/></svg>
            <span class="underline-accent">LinkedIn</span>
          </a>
        </li>
      </ul>
    </nav>
  </div>

  <div class="container-wide footer-bottom">
    <p class="meta">© {year} Kévin Richarte — {t('footer.rights')}</p>
    <div class="footer-bottom-right">
      <a href={r.legal} class="meta legal-link">{t('footer.legal')}</a>
      <LangSwitcher lang={lang} />
    </div>
  </div>
</footer>

<style>
  .site-footer { background: var(--encre); border-top: 1px solid var(--line); padding-block: var(--space-2xl) var(--space-l); }
  .footer-top { display: flex; flex-wrap: wrap; justify-content: space-between; gap: 2.5rem 3rem; padding-bottom: var(--space-2xl); }
  .f-name { font-family: var(--font-serif); font-size: 1.6rem; color: var(--ivoire); }
  .f-role { margin-top: 0.35rem; }
  .f-h { margin-bottom: 0.9rem; }
  .f-col ul { display: flex; flex-direction: column; gap: 0.55rem; }
  .f-link { font-size: 0.9rem; color: var(--ivoire-72); }
  .f-ext { display: inline-flex; align-items: center; gap: 0.6rem; font-size: 0.9rem; color: var(--ivoire-72); transition: color var(--dur) var(--ease); }
  .f-ext:hover { color: var(--ivoire); }
  .f-icon { width: 1.1rem; height: 1.1rem; flex: 0 0 auto; }
  .footer-bottom { display: flex; flex-wrap: wrap; justify-content: space-between; align-items: center; gap: 1rem; padding-top: var(--space-l); border-top: 1px solid var(--line); }
  .footer-bottom-right { display: flex; align-items: center; gap: 1.5rem; }
  .legal-link { transition: color var(--dur) var(--ease); }
  .legal-link:hover { color: var(--ivoire); }
</style>
