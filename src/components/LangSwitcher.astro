---
import { getLangFromUrl, altLangPath, enActive } from '../i18n/utils';
interface Props { lang?: 'fr' | 'en'; }
const lang = Astro.props.lang ?? getLangFromUrl(Astro.url);
const frHref = altLangPath(Astro.url.pathname, 'fr');
const enHref = altLangPath(Astro.url.pathname, 'en');
---
<div class="lang-switch" role="group" aria-label="Langue / Language">
  {enActive ? (
    <a href={frHref} class:list={["ls", { active: lang === 'fr' }]} aria-current={lang === 'fr' ? 'true' : undefined}>FR</a>
  ) : (
    <span class:list={["ls", { active: lang === 'fr' }]}>FR</span>
  )}
  <span class="ls-sep" aria-hidden="true">/</span>
  {enActive
    ? <a href={enHref} class:list={["ls", { active: lang === 'en' }]} aria-current={lang === 'en' ? 'true' : undefined}>EN</a>
    : <span class="ls is-disabled" title="Version anglaise à venir" aria-disabled="true">EN</span>}
</div>

<style>
  .lang-switch {
    display: inline-flex; align-items: center; gap: 0.4rem;
    font-family: var(--font-sans); font-size: 0.72rem; letter-spacing: 0.12em;
  }
  .ls { color: var(--brouillard); }
  .ls.active { color: var(--ivoire); }
  a.ls:hover { color: var(--ambre); }
  .ls.is-disabled { color: var(--cendre); cursor: not-allowed; }
  .ls-sep { color: var(--cendre); }
  :global(.on-ivoire) .ls { color: #6f6455; }
  :global(.on-ivoire) .ls.active { color: var(--encre); }
</style>
