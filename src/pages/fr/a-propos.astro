---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import portrait from '../../assets/portrait.jpg';
import { site } from '../../data/site';
import reglages from '../../data/reglages.json';

// Bio éditable depuis le panneau (Réglages → Bio « À propos »).
// Repli sur ce texte par défaut si le champ est vide (robustesse).
const DEFAULT_BIO = `Chaque projet commence pour moi par une lecture. Avant de toucher aux courbes, je regarde le film, je cherche ce que l'image veut raconter, l'émotion qu'une scène doit porter et la place que la couleur peut y prendre. C'est ma conviction de fond, la couleur est une matière narrative. Un bleu peut être une menace ou un refuge, une peau chaude peut dire l'intimité, et c'est le récit qui décide.

Cette lecture, je la traduis ensuite en propositions concrètes. J'arrive rarement avec un seul look, je préfère présenter plusieurs partis pris argumentés, souvent en captures comparatives, pour que le choix se fasse ensemble et en connaissance de cause. L'étalonnage se construit ensuite en dialogue, par étapes validées, en session à distance depuis mon studio calibré ou en présentiel. Et quand le projet le permet, j'aime être là dès la pré-production, au moment où les choix d'image se décident vraiment.

Si je travaille ainsi, c'est que je suis venu à l'étalonnage par la réalisation. Je garde en mémoire l'essence d'un tournage, ses ambitions artistiques comme ses contraintes techniques, et cela me permet de saisir la mentalité des équipes créatives, de parler récit avec un réalisateur et lumière avec un chef opérateur. Trois ans comme coloriste chez Jellysmack / Keli Network France, avec plus de mille projets étalonnés et des étalonneurs freelance supervisés, m'ont appris le reste, la rigueur, la tenue des délais, et cette exigence de cohérence d'ensemble sans laquelle le plus beau plan ne sert à rien. Aujourd'hui indépendant, certifié DaVinci Resolve, je consacre ce parcours à la fiction, au clip et aux contenus narratifs, avec des travaux dont certains ont été diffusés sur Canal+ et France Télévisions.

L'étalonnage est pour moi une véritable transformation de matière, et j'ai plaisir à en faire un résultat cohérent et engageant. Aux côtés de gens qui ont une histoire à raconter.`;

const bioSource = (reglages.bioTexte ?? '').trim() || DEFAULT_BIO;
const bioParas = bioSource.split(/\n{2,}/).map((s) => s.trim()).filter(Boolean);

// Compétences épurées (moins « CV »)
const competences = [
  { label: 'Outils', items: ['DaVinci Resolve Studio', 'Micro Panel Blackmagic'] },
  { label: 'Espaces & formats', items: ['RAW & LOG', 'ACES', 'Rec.709', 'Livraison multi-formats'] },
  { label: 'Savoir-faire', items: ['Harmonisation multi-sources', 'Simulation pellicule & looks cinéma', 'Création de LUTs', 'Conseil dès la pré-production'] },
];
const formation = [
  { annee: '2020', item: 'DaVinci Resolve Certified End User · Blackmagic Design' },
  { annee: '2018', item: 'Titre RNCP Niveau II Réalisateur-Monteur · ACFA Multimédia, Montpellier' },
  { annee: '2016', item: 'Licence Études cinématographiques et audiovisuelles · Université Montpellier III Paul-Valéry' },
];
---
<BaseLayout title="À propos — Kévin Richarte, étalonneur fiction" lang="fr" description="La démarche et la méthode de Kévin Richarte, étalonneur spécialisé fiction en région parisienne.">
  <!-- Exergue -->
  <section class="section container-read exergue-wrap reveal">
    <p class="meta">À propos</p>
    <blockquote class="exergue">«&nbsp;{site.manifeste}&nbsp;»</blockquote>
  </section>

  <!-- Bio + portrait -->
  <section class="section on-ivoire">
    <div class="container-wide bio-grid">
      <div class="bio-portrait reveal">
        <Image src={portrait} alt="Portrait de Kévin Richarte, étalonneur" widths={[400, 600, 900]} sizes="(max-width:800px) 100vw, 40vw" format="webp" />
      </div>
      <div class="bio-text reveal">
        <p class="meta">Ma démarche</p>
        {bioParas.map((p) => <p>{p}</p>)}
        <div class="diffusions">
          <p class="meta diff-label">Diffusé sur</p>
          <div class="diff-logos">
            <img src="/media/marques/canal.svg" alt="Canal+" loading="lazy" />
            <img src="/media/marques/france-tv.svg" alt="France Télévisions" loading="lazy" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Méthode -->
  <section class="section container-read method-wrap reveal">
    <p class="meta">Approche &amp; méthode</p>
    <ol class="method">
      <li><span class="method-h">Analyser le projet</span> — lire le film d'abord, la technique ensuite.</li>
      <li><span class="method-h">Évaluer les sources</span> — état technique, espaces colorimétriques, points de vigilance.</li>
      <li><span class="method-h">Proposer, argumenté</span> — souvent par comparatifs entre LOG brut, LUT standard et propositions personnelles.</li>
      <li><span class="method-h">Dialoguer</span> — avec le réalisateur et le chef opérateur, tout au long du grading.</li>
      <li><span class="method-h">Livrer</span> — en multi-formats, prêts pour la diffusion.</li>
    </ol>
  </section>

  <!-- Setup + compétences -->
  <section class="section on-ivoire">
    <div class="container-wide two-col">
      <div class="reveal">
        <p class="meta">Studio</p>
        <ul role="list" class="plain-list">
          <li>Studio personnel calibré (gris 18&nbsp;%, moniteur DCI-P3)</li>
          <li>Panneau Blackmagic Micro Panel</li>
          <li>À distance (sessions calibrées par partage d'écran) ou en présentiel</li>
        </ul>
      </div>
      <div class="reveal comp">
        <p class="meta">Compétences</p>
        {competences.map((g) => (
          <div class="comp-group">
            <span class="comp-label">{g.label}</span>
            <p class="comp-items">{g.items.join('  ·  ')}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Formation + langues -->
  <section class="section container-wide two-col formation-wrap reveal">
    <div>
      <p class="meta">Formation &amp; certifications</p>
      <ul role="list" class="timeline">
        {formation.map((f) => (
          <li><span class="tl-year meta">{f.annee}</span><span class="tl-item">{f.item}</span></li>
        ))}
      </ul>
    </div>
    <div>
      <p class="meta">Langues</p>
      <ul role="list" class="plain-list">
        <li>Français — natif</li>
        <li>Anglais — C1 courant</li>
      </ul>
    </div>
  </section>
</BaseLayout>

<style>
  .exergue-wrap { padding-top: var(--space-2xl); }
  .exergue { font-family: var(--font-serif); font-style: italic; font-weight: 300; font-size: var(--step-3); line-height: 1.3; color: var(--ivoire); max-width: 24ch; margin-top: 1.4rem; }

  .bio-grid { display: grid; grid-template-columns: 1fr; gap: 2.5rem; }
  @media (min-width: 800px) { .bio-grid { grid-template-columns: 0.8fr 1.2fr; gap: 4rem; align-items: start; } }
  .bio-portrait :global(img) { width: 100%; aspect-ratio: 4 / 5; object-fit: cover; border: 1px solid var(--line); }
  .bio-text { font-family: var(--font-serif); font-size: 1.18rem; line-height: 1.7; color: var(--encre); }
  .bio-text p { margin-bottom: 1.1rem; max-width: 60ch; }
  .bio-text p:first-of-type { margin-top: 0.8rem; }
  .bio-text em { font-style: italic; }

  .diffusions { margin-top: 2rem; padding-top: 1.6rem; border-top: 1px solid rgba(21, 17, 14, 0.14); }
  .diff-label { margin-bottom: 0.9rem; }
  .diff-logos { display: flex; align-items: center; flex-wrap: wrap; gap: 2rem; }
  .diff-logos img { height: 26px; width: auto; }

  .method { list-style: none; counter-reset: m; margin-top: 1.6rem; display: flex; flex-direction: column; gap: 1.1rem; max-width: 60ch; }
  .method li { counter-increment: m; position: relative; padding-left: 2.6rem; color: var(--ivoire-72); font-family: var(--font-serif); font-size: 1.15rem; line-height: 1.5; }
  .method li::before { content: counter(m, decimal-leading-zero); position: absolute; left: 0; top: 0.15rem; font-family: var(--font-sans); font-size: 0.72rem; letter-spacing: 0.08em; color: var(--ambre); }
  .method-h { color: var(--ivoire); }

  .two-col { display: grid; grid-template-columns: 1fr; gap: 3rem; }
  @media (min-width: 760px) { .two-col { grid-template-columns: 1fr 1fr; } }
  .plain-list { display: flex; flex-direction: column; gap: 0.6rem; margin-top: 1.1rem; color: var(--ivoire-72); }
  :global(.on-ivoire) .plain-list { color: #5a5044; }
  .comp-group { margin-top: 1.3rem; }
  .comp-label { font-family: var(--font-sans); font-size: 0.72rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ambre); }
  .comp-items { font-family: var(--font-serif); font-size: 1.1rem; color: var(--encre); margin-top: 0.35rem; line-height: 1.4; }

  .formation-wrap { padding-top: var(--space-2xl); }
  .timeline { display: flex; flex-direction: column; gap: 1rem; margin-top: 1.1rem; }
  .timeline li { display: grid; grid-template-columns: 5.5rem 1fr; gap: 1rem; align-items: baseline; }
  .tl-year { color: var(--ambre); }
  .tl-item { font-family: var(--font-serif); font-size: 1.1rem; color: var(--ivoire); }
</style>
