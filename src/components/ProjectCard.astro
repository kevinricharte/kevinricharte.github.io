---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import { projectImage } from '../lib/images';

interface Props { entry: CollectionEntry<'projets'>; }
const { entry } = Astro.props;
const d = entry.data;
const cover = projectImage(entry.id, d.cover);
---
<li class="card" data-typos={d.typologies.join('|')}>
  <a href={`/fr/projets/${entry.id}`} class="card-link">
    <div class="card-media">
      {cover && <Image src={cover} alt={d.coverAlt ?? d.titre} widths={[400, 600, 900]} sizes="(max-width:700px) 100vw, (max-width:1100px) 50vw, 33vw" format="webp" class="card-img" />}
      <div class="card-overlay" aria-hidden="true">
        <span class="card-otitle">{d.titre}</span>
        <span class="card-otypo">{d.typologiePrincipale}</span>
      </div>
    </div>
    <div class="card-meta">
      <span class="card-name">{d.titre}</span>
      <span class="meta card-info">{d.annee ?? '—'} · {d.typologiePrincipale}</span>
    </div>
  </a>
</li>

<style>
  .card-media { position: relative; aspect-ratio: 16 / 9; overflow: hidden; background: var(--cendre); }
  .card-img { width: 100%; height: 100%; object-fit: cover; transition: transform 600ms var(--ease); }
  .card-link:hover .card-img, .card-link:focus-visible .card-img { transform: scale(1.04); }
  .card-overlay {
    position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center;
    gap: 0.5rem; text-align: center; padding: 1rem; background: rgba(21, 17, 14, 0.58); opacity: 0;
    transition: opacity var(--dur) var(--ease);
  }
  .card-link:hover .card-overlay, .card-link:focus-visible .card-overlay { opacity: 1; }
  .card-otitle { font-family: var(--font-serif); font-size: clamp(1.4rem, 2.5vw, 1.7rem); color: var(--ivoire); }
  .card-otypo { font-family: var(--font-sans); font-size: 0.68rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ambre); }
  .card-meta { margin-top: 0.9rem; display: flex; flex-direction: column; gap: 0.3rem; }
  .card-name { font-family: var(--font-serif); font-size: 1.2rem; color: var(--ivoire); }
  .card[hidden] { display: none; }
  @media (hover: none) { .card-overlay { display: none; } }
</style>
