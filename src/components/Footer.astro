---
import { getRoutes, useTranslations, getLangFromUrl } from '../i18n/utils';
import LangSwitcher from './LangSwitcher.astro';
import { site } from '../data/site';

interface Props { lang?: 'fr' | 'en'; }
const lang = Astro.props.lang ?? getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const r = getRoutes(lang);
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="container-wide footer-top">
    <div class="f-left">
      <p class="f-name">Kévin Richarte</p>
      <p class="meta f-role">{t('footer.role')}</p>
      <p class="f-contact">
        <a href={`mailto:${site.email}`} class="underline-accent">{site.email}</a>
        <a href={`tel:${site.phoneHref}`} class="underline-accent">{site.phone}</a>
      </p>
    </div>
    <nav class="f-right" aria-label="Liens externes">
      <ul role="list">
        <li><a href={site.showreelUrl} target="_blank" rel="noopener noreferrer" class="f-ext underline-accent">Showreel · Vimeo <span aria-hidden="true">↗</span></a></li>
        <li><a href={site.instagramUrl} target="_blank" rel="noopener noreferrer" class="f-ext underline-accent">Instagram <span aria-hidden="true">↗</span></a></li>
      </ul>
    </nav>
  </div>

  <div class="container-wide footer-bottom">
    <p class="meta">© {year} Kévin Richarte — {t('footer.rights')}</p>
    <div class="footer-bottom-right">
      <a href={r.legal} class="meta legal-link">{t('footer.legal')}</a>
      <LangSwitcher lang={lang} />
    </div>
  </div>
</footer>

<style>
  .site-footer { background: var(--encre); border-top: 1px solid var(--line); padding-block: var(--space-2xl) var(--space-l); }
  .footer-top { display: flex; flex-wrap: wrap; justify-content: space-between; gap: 2.5rem; padding-bottom: var(--space-2xl); }
  .f-name { font-family: var(--font-serif); font-size: 1.6rem; color: var(--ivoire); }
  .f-role { margin-top: 0.35rem; }
  .f-contact { display: flex; flex-direction: column; gap: 0.2rem; margin-top: 1.1rem; color: var(--ivoire-72); font-size: 0.95rem; }
  .f-right ul { display: flex; flex-direction: column; gap: 0.5rem; }
  .f-ext { font-size: 0.85rem; letter-spacing: 0.04em; color: var(--ivoire-72); }
  .footer-bottom { display: flex; flex-wrap: wrap; justify-content: space-between; align-items: center; gap: 1rem; padding-top: var(--space-l); border-top: 1px solid var(--line); }
  .footer-bottom-right { display: flex; align-items: center; gap: 1.5rem; }
  .legal-link { transition: color var(--dur) var(--ease); }
  .legal-link:hover { color: var(--ivoire); }
</style>
